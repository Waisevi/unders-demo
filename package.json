{
  "name": "app-name",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "lint:config": "eslint-config-inspector",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx}'",
    "prepare": "husky",
    "test": "vitest",
    "test:ci": "vitest run",
    "knip": "knip",
    "check-deps": "pnpm outdated --long",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "inspect-modules": "node-modules-inspector",
    "postinstall": "cp public/mockServiceWorker.js .storybook/static/ && npx @import-meta-env/typescript -x .env.example -o ./src/@types && pnpm lint:fix",
    "typecheck": "tsc --noEmit",
    "update-theme": "node --loader ts-node/esm --no-warnings=ExperimentalWarning src/styles/theme/update-tw-theme.mts"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@mui/material-nextjs": "^7.3.6",
    "@sentry/nextjs": "^10.32.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.90.12",
    "clsx": "^2.1.1",
    "cva": "npm:class-variance-authority@^0.7.1",
    "dayjs": "^1.11.19",
    "merge-refs": "^2.0.0",
    "next": "^16.0.10",
    "postcss": "^8.5.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.68.0",
    "react-imask": "^7.6.1",
    "tailwindcss": "^4.1.18",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/config-inspector": "^1.4.2",
    "@hookform/resolvers": "^5.2.2",
    "@storybook/addon-links": "10.1.8",
    "@storybook/nextjs": "10.1.8",
    "@storybook/react": "^10.1.10",
    "@tanstack/eslint-plugin-query": "^5.91.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.27",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.0.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.0.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^27.4.0",
    "knip": "^5.75.1",
    "lint-staged": "^16.2.7",
    "msw": "^2.12.4",
    "msw-storybook-addon": "^2.0.6",
    "node-modules-inspector": "^1.2.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "storybook": "^10.1.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "msw": {
    "workerDirectory": "public"
  }
}
