{
  "extends": [
    "next/core-web-vitals",
    "plugin:@typescript-eslint/recommended",
    "plugin:react/recommended",
    "plugin:prettier/recommended",
    "plugin:sonarjs/recommended"
  ],
  "ignorePatterns": ["**/*.test.ts", "**/*.d.ts", "**/*.stories.tsx"],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "sourceType": "module",
    "ecmaVersion": 10,
    "ecmaFeatures": {
      "jsx": true
    },
    "useJSXTextNode": true,
    "project": "./tsconfig.json",
    "tsconfigRootDir": "./"
  },
  "plugins": ["@typescript-eslint", "prettier", "react", "sonarjs", "jest"],
  "settings": {
    "react": {
      "version": "detect"
    },
    "import/resolver": {
      "node": {
        "extensions": [".tsx", ".ts", ".jsx", ".js"],
        "paths": ["src"]
      }
    }
  },
  "rules": {
    "no-restricted-syntax": [
      "error",
      {
        "selector": "CallExpression[callee.name='styled']>.arguments:nth-child(1)[value=\"a\"]",
        "message": "Do not use direct anchor references. Use components/routing/link instead"
      },
      {
        "selector": "CallExpression[callee.name='styled']>.arguments:nth-child(1)[value=\"button\"]",
        "message": "Do not use direct button references. Use components/ui/button instead"
      },
      {
        "selector": "ImportDeclaration[source.value=\"@stitches/react\"]",
        "message": "Do not use direct '@stitches/react' import. Use const/stitches instead"
      }
    ],
    "react/function-component-definition": [
      "error",
      {
        "namedComponents": ["arrow-function"],
        "unnamedComponents": []
      }
    ],
    "react/destructuring-assignment": [
      "error",
      "always",
      {
        "ignoreClassFields": true,
        "destructureInSignature": "always"
      }
    ],
    "react/react-in-jsx-scope": "off",
    "@typescript-eslint/no-non-null-assertion": "off",
    "@typescript-eslint/no-explicit-any": "off",
    "sonarjs/no-duplicate-string": "off",
    "react/prop-types": "off"
  }
}
